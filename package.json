    "@mdx-js/react": "^3.0.0",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.0.0",
    "postcss": "^8.5.6",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
